// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// 1. Usuarios y Seguridad
// ========================================

enum RoleEnum {
  ADMIN
  OPERATOR
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      RoleEnum @default(OPERATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs    AuditLog[]
  transactions Transaction[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // CREATE, UPDATE, DELETE
  entity    String // Table name
  entityId  String // Record ID
  oldValue  String? // JSON stringified
  newValue  String? // JSON stringified
  createdAt DateTime @default(now())
}

// ========================================
// 2. Parámetros del Sistema
// ========================================

model Parameter {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String // Stringified value
  description String?
  updatedAt   DateTime @updatedAt
}

// ========================================
// 3. Catálogos Base (Terceros y Artículos)
// ========================================

model Provider {
  id               String   @id @default(cuid())
  ruc              String?  @unique
  legalName        String
  tradeName        String?
  address          String?
  phone            String?
  email            String?
  contact          String?
  notes            String?
  isSlaughterhouse Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  batches                 Batch[]
  batchesAsSlaughterhouse Batch[]          @relation("BatchSlaughterhouse")
  expenses                Expense[]
  accountsPayable         AccountPayable[]
}

model Client {
  id              String   @id @default(cuid())
  legalName       String
  tradeName       String?
  phone           String?
  email           String?
  contact         String?
  paymentTermDays Int      @default(0)
  isIvaRetainer   Boolean  @default(false)
  isRentRetainer  Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sales              Sale[]
  accountsReceivable AccountReceivable[]
}

model Item {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  category        String // Carne, Menudencia, etc.
  unit            String // KG, UN
  description     String?
  status          Boolean  @default(true)
  isSlaughterable Boolean  @default(false) // Nuevo: Si es faenable (Ej: Vaca, Toro)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  saleDetails        SaleDetail[]
  batchDetails       BatchDetail[]
  closurePrices      BatchClosurePrice[]
  slaughterDetails   SlaughterDetail[]
  inventoryLots      InventoryLot[]
  inventoryMovements InventoryMovement[]
}

// ========================================
// 4. Operaciones Ganaderas (Compra / Romaneo / Faena)
// ========================================

enum BatchStatus {
  OPEN // Abierto
  IN_SLAUGHTER // En faena
  IN_SALE // En venta
  SOLD // Vendido
  CLOSED // Cerrado
}

// AnimalCategory enum removed in favor of dynamic Items

enum AnimalCondition {
  GORDO
  FLACO
  DESCARTE
  BUENO
  LASTIMADO
}

model Batch {
  id               String      @id @default(cuid())
  batchNumber      Int         @unique @default(autoincrement())
  date             DateTime
  providerId       String
  provider         Provider    @relation(fields: [providerId], references: [id])
  description      String?
  status           BatchStatus @default(OPEN)
  slaughterhouseId String?
  slaughterhouse   Provider?   @relation("BatchSlaughterhouse", fields: [slaughterhouseId], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  details       BatchDetail[]
  closure       BatchClosure?
  slaughter     Slaughter?
  expenses      Expense[]
  inventoryLots InventoryLot[]
}

model BatchDetail {
  id        String          @id @default(cuid())
  batchId   String
  batch     Batch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item            @relation(fields: [itemId], references: [id])
  condition AnimalCondition @default(GORDO)
  quantity  Int
  netWeight Float // Peso neto

  createdAt DateTime @default(now())
}

model BatchClosure {
  id      String @id @default(cuid())
  batchId String @unique
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  // Resumen de pesos
  totalNetWeight      Float // Peso bruto total
  discountApplied     Boolean @default(true)
  discountPercentage  Float   @default(4.0)
  totalDiscountWeight Float
  totalLiquidWeight   Float

  // Valor financiero
  totalValue Float // Suma de (kilos líquidos * precio)

  prices BatchClosurePrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BatchClosurePrice {
  id           String       @id @default(cuid())
  closureId    String
  closure      BatchClosure @relation(fields: [closureId], references: [id], onDelete: Cascade)
  itemId       String
  item         Item         @relation(fields: [itemId], references: [id])
  liquidWeight Float
  pricePerKg   Float
  totalValue   Float
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum SlaughterStatus {
  OPEN
  CLOSED
}

enum SlaughterCondition {
  CON_COBERTURA
  SIN_COBERTURA
  FLACO
  GOLPEADO
}

model Slaughter {
  id      String          @id @default(cuid())
  batchId String          @unique
  batch   Batch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  date    DateTime
  status  SlaughterStatus @default(OPEN)

  // Cierre data
  totalWeight Float?
  yield       Float?

  createdAt DateTime          @default(now())
  details   SlaughterDetail[]
}

model SlaughterDetail {
  id             String             @id @default(cuid())
  slaughterId    String
  slaughter      Slaughter          @relation(fields: [slaughterId], references: [id], onDelete: Cascade)
  sequenceNumber Int                @default(0) // Secuencial 1, 2, 3...
  itemId         String
  item           Item               @relation(fields: [itemId], references: [id])
  condition      SlaughterCondition
  weight         Float // Peso de una media res (0.5 cabeza)

  createdAt DateTime @default(now())
}

// ========================================
// 5. Inventario y Costos
// ========================================

model InventoryLot {
  id           String   @id @default(cuid())
  batchId      String?  // Opcional por si entra inventario manual
  batch        Batch?   @relation(fields: [batchId], references: [id])
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id])
  
  initialStock Float    @default(0) // KG con el que entró
  currentStock Float    @default(0) // KG disponibles
  unitCost     Float    @default(0) // Costo calculado al cierre de faena o manual
  
  movements    InventoryMovement[]
  saleDetails  SaleDetail[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

model InventoryMovement {
  id             String       @id @default(cuid())
  inventoryLotId String
  inventoryLot   InventoryLot @relation(fields: [inventoryLotId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item         @relation(fields: [itemId], references: [id])
  type           MovementType
  quantity       Float // Cantidad movida (siempre positiva)
  stockAfter     Float // Stock resultante tras el movimiento
  date           DateTime     @default(now())
  reference      String? // Ej: "Faena #12", "Venta #001-001-0000001"
  description    String?

  createdAt DateTime @default(now())
}

// ========================================
// 6. Ventas
// ========================================

enum SaleStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Sale {
  id            String     @id @default(cuid())
  date          DateTime
  invoiceNumber String? // Formato 001-001-0000001
  clientId      String
  client        Client     @relation(fields: [clientId], references: [id])
  status        SaleStatus @default(PENDING)
  totalValue    Float      @default(0)
  ivaRetention  Float      @default(0)
  rentRetention Float      @default(0)
  netValue      Float      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  details            SaleDetail[]
  accountsReceivable AccountReceivable[]
}

model SaleDetail {
  id             String       @id @default(cuid())
  saleId         String
  sale           Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  inventoryLotId String
  inventoryLot   InventoryLot @relation(fields: [inventoryLotId], references: [id])
  itemId         String
  item           Item         @relation(fields: [itemId], references: [id])
  quantityKg     Float
  salePrice      Float
  totalValue     Float
  costAtSale     Float // Costo que tenía el lote en ese momento

  createdAt DateTime @default(now())
}

// ========================================
// 7. Finanzas (Bancos, Cuentas, Gastos)
// ========================================

model Currency {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique // PYG, USD, BRL
  symbol       String
  exchangeRate Float    @default(1.0)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  bankAccounts BankAccount[]
}

model BankAccount {
  id             String   @id @default(cuid())
  bankName       String
  accountName    String
  accountNumber  String
  currencyId     String
  currency       Currency @relation(fields: [currencyId], references: [id])
  initialBalance Float    @default(0)
  status         Boolean  @default(true)
  createdAt      DateTime @default(now())

  transactions Transaction[]
}

enum AccountStatus {
  PENDING
  PARTIAL
  PAID
}

model AccountReceivable {
  id         String        @id @default(cuid())
  saleId     String?
  sale       Sale?         @relation(fields: [saleId], references: [id])
  clientId   String
  client     Client        @relation(fields: [clientId], references: [id])
  amount     Float
  paidAmount Float         @default(0)
  status     AccountStatus @default(PENDING)
  dueDate    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PayableType {
  BATCH_PURCHASE
  EXPENSE
}

model AccountPayable {
  id         String        @id @default(cuid())
  sourceId   String // Puede ser batchId o expenseId
  type       PayableType
  providerId String
  provider   Provider      @relation(fields: [providerId], references: [id])
  amount     Float
  paidAmount Float         @default(0)
  status     AccountStatus @default(PENDING)
  dueDate    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  expenses Expense[]
}

model Expense {
  id          String          @id @default(cuid())
  date        DateTime
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  providerId  String
  provider    Provider        @relation(fields: [providerId], references: [id])
  batchId     String?
  batch       Batch?          @relation(fields: [batchId], references: [id])
  description String
  amount      Float

  createdAt DateTime @default(now())
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Transaction {
  id            String          @id @default(cuid())
  date          DateTime
  bankAccountId String
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id])
  type          TransactionType
  amount        Float
  reference     String?
  concept       String
  userId        String
  user          User            @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
